        "number": "01",
        "title": "Gutter Installation",
        "description": "Seamless gutters sized for Colorado—moving water away from your foundation, siding, and landscaping."
      },
      {
        "number": "02",
        "title": "Gutter Repair",
        "description": "Fix leaks, correct pitch, and improve downspouts. We find the cause and restore flow for storms and freeze–thaw cycles."
      },
      {
        "number": "03",
        "title": "Gutter Cleaning",
        "description": "Clear debris, restore flow, and reduce overflow risk—keeps your system working between seasons."
      },
      {
        "number": "04",
        "title": "Gutter Guards",
        "description": "Fewer clogs, less ladder time—guards keep debris out while water keeps moving."
      },
      {
        "number": "05",
        "title": "Heated Gutters",
        "description": "Cut ice buildup and backups. We match the right heat solution to your roofline so meltwater drains."
      },
      {
        "number": "06",
        "title": "Soffit & Fascia",
        "description": "Repair or replace soffit and fascia to protect edges and ventilation—and keep water out."
      }
    ]
  },
