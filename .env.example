# Vercel → Project → Settings → Environment Variables (Production + Preview).
# Never commit real secrets to git.

# Zapier: Create Zap → Webhooks by Zapier → Catch Hook → copy the POST URL
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXX/YYYYY/

# Google reCAPTCHA v3: Admin console → register site → Keys
# Use the *secret* key here only. The *site* key goes in shared/homepage-content.json → forms.recaptchaSiteKey
RECAPTCHA_SECRET_KEY=

# Optional: reject scores below this (0.0–1.0). Default 0.35. Raise if you get spam.
# RECAPTCHA_MIN_SCORE=0.5
