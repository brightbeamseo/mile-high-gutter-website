# Vercel → Project → Settings → Environment Variables (Production + Preview).
# Never commit real secrets to git.

# Zapier: Create Zap → Webhooks by Zapier → Catch Hook → copy the POST URL
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXX/YYYYY/

# reCAPTCHA removed from the lead form for now. You can delete RECAPTCHA_* from Vercel if set.

# Sanity write API (scripts / lib/sanity-write.js — never commit token; never expose to browser)
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_VERSION=2024-01-01
# SANITY_API_TOKEN=
# Import script writes documents: _id siteSettingsSingleton / homePageSingleton (_type unchanged).
