# Optional: Sanity, etc. Lead forms use /api/lead + ZAPIER_WEBHOOK_URL on Vercel only.
# reCAPTCHA v3: public site key (optional — BaseLayout falls back to production key).
PUBLIC_RECAPTCHA_SITE_KEY=
# reCAPTCHA v3 secret (required on Vercel for /api/lead). From Google admin console.
RECAPTCHA_SECRET_KEY=
# Optional: minimum score 0.0–1.0 (default 0.5).
# RECAPTCHA_MIN_SCORE=0.5
