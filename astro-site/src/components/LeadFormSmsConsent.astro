---
/**
 * TCPA-style SMS marketing consent — include on every lead form.
 * Props: unique idPrefix per form (for input id / label for).
 */
interface Props {
  idPrefix: string
  variant?: 'hero' | 'contact'
}
const { idPrefix, variant = 'hero' } = Astro.props
const wrapClass =
  variant === 'contact'
    ? 'contact-form-field contact-form-field-full lead-form-sms-consent'
    : 'hero-form-field hero-form-field-full lead-form-sms-consent'
const cbId = `${idPrefix}-sms-marketing-opt-in`
---

<div class={wrapClass}>
  <label for={cbId} class="lead-form-sms-consent-label">
    <input
      type="checkbox"
      id={cbId}
      name="smsMarketingOptIn"
      value="yes"
      required
      class="lead-form-sms-consent-checkbox"
    />
    <span class="lead-form-sms-consent-copy">
      <span class="lead-form-sms-consent-kicker">
        SMS <span class="required-mark" aria-hidden="true">*</span>
      </span>
      <span class="lead-form-sms-consent-text">
        Recurring texts from <strong>Mile High Gutter</strong> at my number. Msg/data rates may apply. Reply{' '}
        <strong>STOP</strong> to opt out, <strong>HELP</strong> for help. Agree to the{' '}
        <a href="/privacy-policy/" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
        {' '}&{' '}
        <a href="/terms-of-service/" target="_blank" rel="noopener noreferrer">Terms</a>.
      </span>
    </span>
  </label>
</div>
