---
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'
import '../../../styles.css'
import { buildHomeAndConstructionBusinessJsonLd } from '../lib/local-business-json-ld.js'
import { getSiteSettings } from '../lib/site-settings.js'
import { buildThemeCss } from '../lib/theme-css.js'

const { title, description, theme, forms, homeRevealAnimations = false, lcpImageSrc = '' } = Astro.props

const settings = await getSiteSettings()
const localBusinessJsonLd = buildHomeAndConstructionBusinessJsonLd(settings)

if (!forms || typeof forms.submitPath !== 'string' || !forms.submitPath.trim()) {
  throw new Error('BaseLayout: forms.submitPath is required (set from Sanity siteSettings.forms).')
}

const themeCss = buildThemeCss(theme)

const recaptchaSiteKey =
  (import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '').trim() ||
  '6LdBAJgsAAAAAEEaAljBBQUMkyJaEfhw0Bas6ZKL'
const mapboxTokenFromEnv = (import.meta.env.PUBLIC_MAPBOX_TOKEN || '').trim()
const mapboxTokenFromCms =
  typeof settings?.forms?.mapboxPublicToken === 'string' ? settings.forms.mapboxPublicToken.trim() : ''
const mapboxToken = mapboxTokenFromEnv || mapboxTokenFromCms
const formsForClient = { ...forms, recaptchaSiteKey, mapboxToken }
const formsJson = JSON.stringify(formsForClient).replace(/</g, '\\u003c')
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Google Tag Manager (deferred to avoid competing with LCP) -->
    <script is:inline>
      (function (w, d, s, l, i) {
        var loaded = false;
        function loadGtm() {
          if (loaded) return;
          loaded = true;
          w[l] = w[l] || [];
          w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
          var f = d.getElementsByTagName(s)[0];
          var j = d.createElement(s);
          var dl = l != 'dataLayer' ? '&l=' + l : '';
          j.async = true;
          j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
          if (f && f.parentNode) f.parentNode.insertBefore(j, f);
        }
        var trigger = function () {
          loadGtm();
          w.removeEventListener('pointerdown', trigger, { passive: true });
          w.removeEventListener('keydown', trigger, { passive: true });
          w.removeEventListener('scroll', trigger, { passive: true });
        };
        w.addEventListener('pointerdown', trigger, { once: true, passive: true });
        w.addEventListener('keydown', trigger, { once: true, passive: true });
        w.addEventListener('scroll', trigger, { once: true, passive: true });
        w.setTimeout(loadGtm, 5000);
      })(window, document, 'script', 'dataLayer', 'GTM-MVS522LX');
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {localBusinessJsonLd ? (
      <script type="application/ld+json" set:html={localBusinessJsonLd} />
    ) : null}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://services.leadconnectorhq.com" crossorigin />
    <link rel="preconnect" href="https://backend.leadconnectorhq.com" crossorigin />
    <link rel="preconnect" href="https://widgets.leadconnectorhq.com" crossorigin />
    <link rel="preconnect" href="https://cdn.callrail.com" />
    {lcpImageSrc ? <link rel="preload" as="image" href={lcpImageSrc} fetchpriority="high" /> : null}
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=optional"
    />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&display=optional"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=optional"
      media="print"
      onload="this.media='all'"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&display=optional"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=optional"
      />
    </noscript>
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&display=optional"
      />
    </noscript>
    <script type="application/json" id="site-forms-config" set:html={formsJson} />
  </head>
  <body class:list={[{ 'home-reveal-animate': homeRevealAnimations }]}>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MVS522LX"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />
    <!-- CallRail — after main HTML so numbers are in DOM; blocking load for quick swap -->
    <script
      type="text/javascript"
      src="https://cdn.callrail.com/companies/604562685/1a8bc4c0916c3877f4ed/12/swap.js"></script>
    <!-- After bundled styles.css so :root theme tokens override file defaults -->
    <style id="site-theme-vars" set:html={themeCss}></style>
    <Analytics />
    <SpeedInsights />
    <script src="/script.js" defer></script>
    <!-- GoHighLevel / LeadConnector chat widget -->
    <script
      is:inline
      src="https://widgets.leadconnectorhq.com/loader.js"
      data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js"
      data-widget-id="69ce8d738cea9df43402e96e"></script>
    <script is:inline>
      (function () {
        var STYLE_ID = 'mhg-ghl-above-recaptcha';
        var GAP = 12;
        var BOOST = 28;
        var MIN_LIFT = 80;
        /**
         * Lift the launcher above the reCAPTCHA badge (viewport bottom offset).
         * Avoid transform on .lc_text-widget — it breaks fixed-position children (greeting vs bubble misaligned, overlap with page content).
         */
        function liftPx() {
          var badges = document.querySelectorAll('.grecaptcha-badge');
          var best = 0;
          for (var i = 0; i < badges.length; i++) {
            var r = badges[i].getBoundingClientRect();
            if (r.width < 4 || r.height < 4) continue;
            var raw = Math.ceil(window.innerHeight - r.top + GAP + BOOST);
            if (raw > best) best = raw;
          }
          if (best <= 0) return 0;
          return Math.max(MIN_LIFT, best);
        }
        function tightenGreetingCallout(host) {
          var sr = host && host.shadowRoot;
          if (!sr) return;
          var root = sr.querySelector('.lc_text-widget:not(.lc_text-widget--embedded-live-chat)');
          if (!root) return;
          var els = root.getElementsByTagName('*');
          for (var i = 0; i < els.length; i++) {
            var el = els[i];
            if (el.closest && el.closest('.lc_text-widget--bubble')) continue;
            var cs = window.getComputedStyle(el);
            if (cs.position !== 'fixed') continue;
            var r = el.getBoundingClientRect();
            if (r.width < 140 || r.height < 32 || r.height > 280) continue;
            el.style.setProperty('max-width', 'min(340px, calc(100vw - 28px))', 'important');
            el.style.setProperty('right', 'max(16px, env(safe-area-inset-right, 0px))', 'important');
            el.style.setProperty('left', 'auto', 'important');
            el.style.setProperty('box-sizing', 'border-box', 'important');
          }
        }
        function paint(host, px) {
          if (!host || px <= 0) return;
          var css =
            '.lc_text-widget:not(.lc_text-widget--embedded-live-chat){' +
            'transform:none!important;' +
            'transform-origin:initial!important;' +
            'right:max(16px,env(safe-area-inset-right,0px))!important;' +
            'left:auto!important;' +
            'max-width:min(360px,calc(100vw - 24px))!important;' +
            'width:auto!important;' +
            'box-sizing:border-box!important;' +
            '}' +
            '.lc_text-widget--bubble:not(.inline){' +
            'bottom:' +
            px +
            'px!important;' +
            'right:max(16px,env(safe-area-inset-right,0px))!important;' +
            'left:auto!important;' +
            '}';
          if (host.shadowRoot) {
            host.style.transform = '';
            var el = host.shadowRoot.getElementById(STYLE_ID);
            if (!el) {
              el = document.createElement('style');
              el.id = STYLE_ID;
              host.shadowRoot.appendChild(el);
            }
            el.textContent = css;
            window.requestAnimationFrame(function () {
              window.requestAnimationFrame(function () {
                tightenGreetingCallout(host);
              });
            });
          } else {
            host.style.display = 'block';
            host.style.transform = '';
          }
        }
        function sync() {
          var host = document.querySelector('chat-widget');
          var px = liftPx();
          if (host && px > 0) paint(host, px);
        }
        function poll() {
          if (window.__mhgGhlPoll) return;
          window.__mhgGhlPoll = true;
          var n = 0;
          var id = window.setInterval(function () {
            n += 1;
            sync();
            if (n >= 100) window.clearInterval(id);
          }, 150);
        }
        function onResize() {
          clearTimeout(window.__mhgGhlLiftT);
          window.__mhgGhlLiftT = window.setTimeout(sync, 80);
        }
        window.addEventListener('resize', onResize, { passive: true });
        window.addEventListener('LC_chatWidgetLoaded', poll, false);
        if (document.readyState === 'complete') poll();
        else window.addEventListener('load', poll);
        var mo = new MutationObserver(sync);
        mo.observe(document.documentElement, { childList: true, subtree: true });
        window.setTimeout(function () {
          mo.disconnect();
        }, 30000);
      })();
    </script>
  </body>
</html>
