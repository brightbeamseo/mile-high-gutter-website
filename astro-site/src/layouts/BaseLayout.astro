---
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'
import '../../../styles.css'
import { buildHomeAndConstructionBusinessJsonLd } from '../lib/local-business-json-ld.js'
import { getSiteSettings } from '../lib/site-settings.js'
import { buildThemeCss } from '../lib/theme-css.js'

const { title, description, theme, forms, homeRevealAnimations = false, lcpImageSrc = '' } = Astro.props

const settings = await getSiteSettings()
const localBusinessJsonLd = buildHomeAndConstructionBusinessJsonLd(settings)

if (!forms || typeof forms.submitPath !== 'string' || !forms.submitPath.trim()) {
  throw new Error('BaseLayout: forms.submitPath is required (set from Sanity siteSettings.forms).')
}

const themeCss = buildThemeCss(theme)

const recaptchaSiteKey =
  (import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '').trim() ||
  '6LdBAJgsAAAAAEEaAljBBQUMkyJaEfhw0Bas6ZKL'
const mapboxTokenFromEnv = (import.meta.env.PUBLIC_MAPBOX_TOKEN || '').trim()
const mapboxTokenFromCms =
  typeof settings?.forms?.mapboxPublicToken === 'string' ? settings.forms.mapboxPublicToken.trim() : ''
const mapboxToken = mapboxTokenFromEnv || mapboxTokenFromCms
const formsForClient = { ...forms, recaptchaSiteKey, mapboxToken }
const formsJson = JSON.stringify(formsForClient).replace(/</g, '\\u003c')
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Google Tag Manager (deferred to avoid competing with LCP) -->
    <script is:inline>
      (function (w, d, s, l, i) {
        var loaded = false;
        function loadGtm() {
          if (loaded) return;
          loaded = true;
          w[l] = w[l] || [];
          w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
          var f = d.getElementsByTagName(s)[0];
          var j = d.createElement(s);
          var dl = l != 'dataLayer' ? '&l=' + l : '';
          j.async = true;
          j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
          if (f && f.parentNode) f.parentNode.insertBefore(j, f);
        }
        var trigger = function () {
          loadGtm();
          w.removeEventListener('pointerdown', trigger, { passive: true });
          w.removeEventListener('keydown', trigger, { passive: true });
          w.removeEventListener('scroll', trigger, { passive: true });
        };
        w.addEventListener('pointerdown', trigger, { once: true, passive: true });
        w.addEventListener('keydown', trigger, { once: true, passive: true });
        w.addEventListener('scroll', trigger, { once: true, passive: true });
        w.setTimeout(loadGtm, 5000);
      })(window, document, 'script', 'dataLayer', 'GTM-MVS522LX');
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {localBusinessJsonLd ? (
      <script type="application/ld+json" set:html={localBusinessJsonLd} />
    ) : null}
    <link rel="icon" href="/favicon.png" type="image/png" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://services.leadconnectorhq.com" crossorigin />
    <link rel="preconnect" href="https://backend.leadconnectorhq.com" crossorigin />
    {lcpImageSrc ? <link rel="preload" as="image" href={lcpImageSrc} fetchpriority="high" /> : null}
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=optional"
    />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&display=optional"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=optional"
      media="print"
      onload="this.media='all'"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&display=optional"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=optional"
      />
    </noscript>
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&display=optional"
      />
    </noscript>
    <script type="application/json" id="site-forms-config" set:html={formsJson} />
  </head>
  <body class:list={[{ 'home-reveal-animate': homeRevealAnimations }]}>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MVS522LX"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />
    <!-- After bundled styles.css so :root theme tokens override file defaults -->
    <style id="site-theme-vars" set:html={themeCss}></style>
    <Analytics />
    <SpeedInsights />
    <script src="/script.js" defer></script>
  </body>
</html>
