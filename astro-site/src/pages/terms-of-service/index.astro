---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { sanity } from '../../lib/sanity.js'
import { getSiteSettings } from '../../lib/site-settings.js'
import { asStr } from '../../lib/sanity-strings.js'

let settings = {}
let legal = {}
try {
  ;[settings, legal] = await Promise.all([
    getSiteSettings(),
    sanity.fetch(`*[_type == "legalPage" && slug.current == "terms-of-service"][0]{title, content}`),
  ])
} catch (err) {
  console.warn('[terms-of-service] Sanity fetch failed.', err)
}

const legalTitle = asStr(legal?.title) || 'Terms of Service'
const legalContent =
  asStr(legal?.content) ||
  'Add your Terms of Service legal copy in Sanity under the Legal content type.'
---

<BaseLayout
  title={`${legalTitle} | Mile High Gutters`}
  description="Terms of Service for Mile High Gutters."
  theme={settings?.theme}
  forms={{ submitPath: asStr(settings?.forms?.submitPath) || '/api/lead' }}
>
  <main class="section">
    <div class="container" style="max-width: 70ch;">
      <h1 class="section-title section-title-secondary">{legalTitle}</h1>
      <p style="white-space: pre-line; line-height: 1.75; margin-top: 1rem;">{legalContent}</p>
    </div>
  </main>
</BaseLayout>
