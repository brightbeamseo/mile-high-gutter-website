{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/:path*.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/script.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }]
    },
    {
      "source": "/lp/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "milehighgutter.com"
        }
      ],
      "destination": "https://www.milehighgutter.com/$1",
      "permanent": true
    },
    {
      "source": "/city-service-base/",
      "destination": "/products-services/gutter-repair-denver-co/",
      "permanent": true
    },
    {
      "source": "/:path((?!api/)(?!.*\\.).*[^/])",
      "destination": "/:path/",
      "permanent": true
    }
  ],
  "functions": {
    "api/lead.js": {
      "maxDuration": 30
    }
  }
}
